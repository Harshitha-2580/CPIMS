
<!DOCTYPE html>
<html lang="zxx">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>NEC Placement Cell – Admin Dashboard</title>
        
        <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&display=swap" rel="stylesheet">

        <link rel="stylesheet" href="assets/css/bootstrap.min.css">
        <link rel="stylesheet" href="assets/css/swiper-bundle.min.css">
        <link rel="stylesheet" href="assets/css/scrollCue.css">
        <link rel="stylesheet" href="assets/css/remixicon.css">
        <link rel="stylesheet" href="assets/css/flaticon.css">
        <link rel="stylesheet" href="assets/css/style.css">
        <link rel="stylesheet" href="assets/css/admin-theme.css">
        <link rel="stylesheet" href="assets/css/responsive.css">
        <link href="assets/img/crop_nec.png" type="image/x-icon" rel="icon">

        <style>
            :root {
                --primaryColor: #001e43;
                --secondaryColor: #002a5c;
                --accentColor: #003580;
                --darkColor: rgb(0, 30, 67);
                --lightGray: #f8f9fa;
                --cardBg: #ffffff;
                --textColor: #333;
                --textLight: #666;
                --borderColor: #e9ecef;
                --shadowColor: rgba(0, 30, 67, 0.1);
                --gradientPrimary: linear-gradient(135deg, #001e43, #002a5c);
                --gradientSecondary: linear-gradient(135deg, #002a5c, #003580);
            }

            body {
                padding-top: 0;
                overflow-x: hidden;
                background: linear-gradient(135deg, #f8f9fa 0%, #f0f2f5 100%);
            }

            /* Welcome Banner Section */
            .admin-welcome-banner {
                background: var(--gradientPrimary);
                padding: 52px 0 36px;
                color: white;
                position: relative;
                overflow: hidden;
                box-shadow: 0 10px 40px var(--shadowColor);
            }

            .admin-welcome-banner::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
                animation: shimmer 4s infinite;
            }

            .admin-welcome-banner::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                height: 6px;
                background: var(--gradientSecondary);
                animation: borderGlow 3s ease-in-out infinite alternate;
            }

            .admin-welcome-content {
                position: relative;
                z-index: 2;
                text-align: center;
            }

            .admin-welcome-title {
                font-size: 48px;
                font-weight: 800;
                margin-bottom: 15px;
                animation: titleFadeIn 1s ease-out;
                color: #ffffff;
                text-shadow: 0 2px 4px rgba(0,0,0,0.3);
                letter-spacing: -1px;
            }

            .admin-welcome-subtitle {
                font-size: 20px;
                opacity: 0.95;
                animation: subtitleFadeIn 1s ease-out 0.3s backwards;
                color: #ffffff;
                font-weight: 400;
                margin-bottom: 30px;
            }

            .admin-stats {
                display: flex;
                justify-content: center;
                gap: 40px;
                margin-top: 40px;
                animation: statsSlideUp 1s ease-out 0.6s backwards;
            }

            .stat-item {
                text-align: center;
                padding: 20px;
                background: rgba(255,255,255,0.1);
                border-radius: 15px;
                backdrop-filter: blur(10px);
                border: 1px solid rgba(255,255,255,0.2);
                transition: all 0.3s ease;
            }

            .stat-item:hover {
                transform: translateY(-5px);
                background: rgba(255,255,255,0.15);
            }

            .stat-number {
                font-size: 32px;
                font-weight: 700;
                color: #ffffff;
                display: block;
                margin-bottom: 5px;
            }

            .stat-label {
                font-size: 14px;
                color: rgba(255,255,255,0.9);
                font-weight: 500;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

            @keyframes bannerSlideIn {
                from {
                    opacity: 0;
                    transform: translateY(-30px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @keyframes titleFadeIn {
                from {
                    opacity: 0;
                    transform: translateY(30px) scale(0.95);
                }
                to {
                    opacity: 1;
                    transform: translateY(0) scale(1);
                }
            }

            @keyframes subtitleFadeIn {
                from {
                    opacity: 0;
                    transform: translateX(-30px);
                }
                to {
                    opacity: 1;
                    transform: translateX(0);
                }
            }

            @keyframes statsSlideUp {
                from {
                    opacity: 0;
                    transform: translateY(40px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @keyframes borderGlow {
                from { opacity: 0.6; }
                to { opacity: 1; }
            }

            @keyframes shimmer {
                0% { left: -100%; }
                100% { left: 100%; }
            }

            /* Modern Dashboard Body Styling */
            .admin-dashboard-body {
                padding: 34px 0;
                background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
                min-height: 100vh;
            }

            .dashboard-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                grid-template-rows: min-content min-content;
                grid-template-areas:
                    "quick-stats performance system-overview"
                    "quick-actions management-tools activity-feed";
                gap: 18px;
                padding: 0 12px;
                max-width: 1400px;
                margin: 0 auto;
            }

            .quick-stats-widget {
                grid-area: quick-stats;
            }

            .performance-widget {
                grid-area: performance;
            }

            .system-overview-widget {
                grid-area: system-overview;
            }

            .quick-actions-widget {
                grid-area: quick-actions;
            }

            .management-tools-widget {
                grid-area: management-tools;
            }

            .activity-feed-widget {
                grid-area: activity-feed;
            }

            /* Dashboard Widgets */
            .dashboard-widget {
                background: rgba(255, 255, 255, 0.95);
                backdrop-filter: blur(20px);
                border-radius: 24px;
                border: 1px solid rgba(0, 30, 67, 0.1);
                box-shadow: 0 20px 60px rgba(0, 30, 67, 0.08);
                overflow: hidden;
                transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
                animation: widgetSlideIn 0.8s ease-out backwards;
                position: relative;
            }

            .dashboard-widget:nth-child(1) { animation-delay: 0.1s; }
            .dashboard-widget:nth-child(2) { animation-delay: 0.2s; }
            .dashboard-widget:nth-child(3) { animation-delay: 0.3s; }
            .dashboard-widget:nth-child(4) { animation-delay: 0.4s; }
            .dashboard-widget:nth-child(5) { animation-delay: 0.5s; }
            .dashboard-widget:nth-child(6) { animation-delay: 0.6s; }

            .dashboard-widget:hover {
                transform: translateY(-8px);
                box-shadow: 0 30px 80px rgba(0, 30, 67, 0.15);
                border-color: rgba(0, 30, 67, 0.2);
            }

            .dashboard-widget::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 4px;
                background: var(--gradientPrimary);
                transform: scaleX(0);
                transition: transform 0.4s ease;
                transform-origin: left;
            }

            .dashboard-widget:hover::before {
                transform: scaleX(1);
            }

            @keyframes widgetSlideIn {
                from {
                    opacity: 0;
                    transform: translateY(40px) scale(0.95);
                }
                to {
                    opacity: 1;
                    transform: translateY(0) scale(1);
                }
            }

            /* Widget Header */
            .widget-header {
                display: flex;
                align-items: center;
                gap: 15px;
                padding: 18px 22px 14px;
                border-bottom: 1px solid rgba(0, 30, 67, 0.08);
                background: linear-gradient(135deg, rgba(0, 30, 67, 0.02), rgba(0, 42, 92, 0.02));
            }

            .widget-icon {
                width: 50px;
                height: 50px;
                border-radius: 16px;
                background: var(--gradientPrimary);
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 24px;
                box-shadow: 0 8px 25px rgba(0, 30, 67, 0.2);
            }

            .widget-title h3 {
                color: var(--darkColor);
                font-size: 20px;
                font-weight: 700;
                margin: 0 0 2px 0;
            }

            .widget-title p {
                color: var(--textLight);
                font-size: 14px;
                margin: 0;
                font-weight: 500;
            }

            /* Widget Content */
            .widget-content {
                padding: 16px 22px;
            }

            /* Quick Actions Widget */
            .action-buttons-grid {
                display: flex;
                flex-direction: column;
                gap: 10px;
            }

            .action-button {
                background: linear-gradient(135deg, #f8f9fa, #ffffff);
                border: 2px solid rgba(0, 30, 67, 0.1);
                border-radius: 16px;
                padding: 20px 15px;
                text-align: center;
                cursor: pointer;
                transition: all 0.3s ease;
                position: relative;
                overflow: hidden;
            }

            .action-button::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: var(--gradientPrimary);
                transition: left 0.4s ease;
                z-index: -1;
            }

            .action-button:hover::before {
                left: 0;
            }

            .action-button:hover {
                border-color: var(--primaryColor);
                transform: translateY(-3px);
                box-shadow: 0 10px 30px rgba(0, 30, 67, 0.15);
            }

            .action-button:hover .action-icon i {
                color: white;
                transform: scale(1.1);
            }

            .action-button:hover span {
                color: white;
            }

            .action-icon {
                width: 40px;
                height: 40px;
                border-radius: 12px;
                background: rgba(0, 30, 67, 0.1);
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 10px;
                transition: all 0.3s ease;
            }

            .action-icon i {
                font-size: 20px;
                color: var(--primaryColor);
                transition: all 0.3s ease;
            }

            .action-button span {
                font-size: 13px;
                font-weight: 600;
                color: var(--darkColor);
                transition: color 0.3s ease;
            }

            /* System Overview Widget */
            .overview-metrics {
                display: flex;
                justify-content: space-around;
                gap: 20px;
            }

            .metric-item {
                flex: 1;
                text-align: center;
            }

            .metric-circle {
                width: 100px;
                height: 100px;
                border-radius: 50%;
                background: var(--gradientPrimary);
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                margin: 0 auto 15px;
                box-shadow: 0 10px 30px rgba(0, 30, 67, 0.2);
                position: relative;
                overflow: hidden;
            }

            .metric-circle::before {
                content: '';
                position: absolute;
                top: -50%;
                left: -50%;
                width: 200%;
                height: 200%;
                background: conic-gradient(from 0deg, rgba(255,255,255,0.1) 0deg, transparent 180deg);
                animation: rotate 4s linear infinite;
            }

            @keyframes rotate {
                from { transform: rotate(0deg); }
                to { transform: rotate(360deg); }
            }

            .metric-number {
                font-size: 24px;
                font-weight: 700;
                color: white;
                position: relative;
                z-index: 1;
            }

            .metric-label {
                font-size: 11px;
                color: rgba(255,255,255,0.9);
                font-weight: 500;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                position: relative;
                z-index: 1;
            }

            /* Admin Stats Panel */
            .admin-stats-panel {
                background: #fff;
                border-radius: 15px;
                padding: 35px;
                box-shadow: 0 5px 20px rgba(0,0,0,0.08);
                animation: slideInRight 0.6s ease-out 0.2s backwards;
            }

            @keyframes slideInRight {
                from {
                    opacity: 0;
                    transform: translateX(40px);
                }
                to {
                    opacity: 1;
                    transform: translateX(0);
                }
            }

            .stats-header {
                margin-bottom: 30px;
                border-bottom: 2px solid #f0f0f0;
                padding-bottom: 15px;
            }

            .stats-header h3 {
                color: var(--darkColor);
                font-weight: 700;
                font-size: 22px;
                margin: 0;
            }

            .stats-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 20px;
                margin-bottom: 30px;
            }

            .stat-card {
                background: linear-gradient(135deg, #f8f9fa 0%, #f0f2f5 100%);
                padding: 20px;
                border-radius: 12px;
                display: flex;
                align-items: center;
                gap: 15px;
                transition: all 0.3s ease;
                border: 2px solid transparent;
            }

            .stat-card:hover {
                background: linear-gradient(135deg, #fff 0%, #f8f9fa 100%);
                transform: translateY(-5px);
                border-color: var(--primaryColor);
                box-shadow: 0 8px 25px rgba(37, 99, 235, 0.15);
            }

            .stat-icon {
                width: 60px;
                height: 60px;
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 28px;
                min-width: 60px;
            }

            .placement-icon {
                background: linear-gradient(135deg, rgba(37, 99, 235, 0.15), rgba(37, 99, 235, 0.05));
                color: var(--primaryColor);
            }

            .student-icon {
                background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(59, 130, 246, 0.05));
                color: var(--secondaryColor);
            }

            .company-icon {
                background: linear-gradient(135deg, rgba(96, 165, 250, 0.15), rgba(96, 165, 250, 0.05));
                color: #60a5fa;
            }

            .faculty-icon {
                background: linear-gradient(135deg, rgba(147, 197, 253, 0.15), rgba(147, 197, 253, 0.05));
                color: #93c5fd;
            }

            .stat-content h5 {
                color: #666;
                font-size: 13px;
                font-weight: 600;
                margin: 0 0 8px 0;
                text-transform: uppercase;
            }

            .stat-number {
                color: var(--darkColor);
                font-size: 28px;
                font-weight: 800;
                margin: 0;
            }

            /* Quick Info Section */
            .quick-info-section {
                background: linear-gradient(135deg, #f8f9fa 0%, #f0f2f5 100%);
                padding: 20px;
                border-radius: 12px;
                border-left: 4px solid var(--primaryColor);
            }

            .quick-info-section h4 {
                color: var(--darkColor);
                font-weight: 700;
                margin: 0 0 15px 0;
                font-size: 16px;
            }

            .info-item {
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 10px;
                padding: 8px 0;
                transition: all 0.3s ease;
            }

            .info-item:last-child {
                margin-bottom: 0;
            }

            .status-dot {
                width: 10px;
                height: 10px;
                border-radius: 50%;
                animation: pulse 2s ease-in-out infinite;
            }

            .status-dot.active {
                background: #4caf50;
                box-shadow: 0 0 8px rgba(76, 175, 80, 0.6);
            }

            @keyframes pulse {
                0%, 100% { opacity: 1; }
                50% { opacity: 0.6; }
            }

            .info-text {
                color: #666;
                font-size: 14px;
                font-weight: 500;
            }

            /* Responsive */
            @media (max-width: 992px) {
                .stats-grid {
                    grid-template-columns: 1fr;
                }

                .vertical-cards-section {
                    margin-bottom: 30px;
                }
            }

            .single-admin-card .icon {
                display: inline-block;
                width: 70px;
                height: 70px;
                background: linear-gradient(135deg, rgba(250, 57, 74, 0.1), rgba(255, 195, 51, 0.1));
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 20px;
                transition: all 0.3s ease;
            }

            .single-admin-card:hover .icon {
                background: linear-gradient(135deg, var(--primaryColor), var(--secenderyColor));
                transform: scale(1.1) rotate(5deg);
            }

            .single-admin-card:hover .icon i {
                color: white !important;
            }

            .single-admin-card .icon i {
                font-size: 40px;
                color: var(--primaryColor);
                transition: all 0.3s ease;
            }

            .single-admin-card h4 {
                font-size: 22px;
                font-weight: 700;
                color: var(--darkColor);
                margin-bottom: 12px;
                transition: all 0.3s ease;
            }

            .single-admin-card:hover h4 {
                color: var(--primaryColor);
            }

            .single-admin-card p {
                font-size: 14px;
                color: #666;
                margin: 0;
                line-height: 1.6;
            }

            /* Style for the active nav link */
            .navbar-nav .nav-link.active-admin {
                color: var(--primaryColor) !important;
                font-weight: bold;
            }

            /* Activity Feed Widget */
            .activity-list {
                max-height: 300px;
                overflow-y: auto;
                scrollbar-width: thin;
                scrollbar-color: var(--primaryColor) transparent;
            }

            .activity-list::-webkit-scrollbar {
                width: 6px;
            }

            .activity-list::-webkit-scrollbar-track {
                background: rgba(0, 30, 67, 0.05);
                border-radius: 3px;
            }

            .activity-list::-webkit-scrollbar-thumb {
                background: var(--primaryColor);
                border-radius: 3px;
            }

            .activity-item {
                display: flex;
                align-items: flex-start;
                gap: 15px;
                padding: 15px 0;
                border-bottom: 1px solid rgba(0, 30, 67, 0.05);
                transition: all 0.2s ease;
            }

            .activity-item:hover {
                background: rgba(0, 30, 67, 0.02);
                border-radius: 8px;
                margin: 0 -10px;
                padding: 15px 10px;
            }

            .activity-item:last-child {
                border-bottom: none;
            }

            .activity-dot {
                width: 10px;
                height: 10px;
                border-radius: 50%;
                background: var(--gradientPrimary);
                margin-top: 6px;
                flex-shrink: 0;
                box-shadow: 0 0 10px rgba(0, 30, 67, 0.3);
            }

            .activity-content p {
                font-size: 14px;
                color: var(--darkColor);
                margin: 0 0 3px 0;
                font-weight: 500;
            }

            .activity-time {
                font-size: 12px;
                color: var(--textLight);
                font-weight: 400;
            }

            /* Performance Metrics Widget */
            .performance-bars {
                display: flex;
                flex-direction: column;
                gap: 20px;
            }

            .performance-item {
                position: relative;
            }

            .performance-label {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 8px;
            }

            .performance-label span:first-child {
                font-size: 14px;
                font-weight: 600;
                color: var(--darkColor);
            }

            .percentage {
                font-size: 14px;
                font-weight: 700;
                color: var(--primaryColor);
            }

            .progress-bar {
                height: 8px;
                background: rgba(0, 30, 67, 0.1);
                border-radius: 4px;
                overflow: hidden;
                position: relative;
            }

            .progress-fill {
                height: 100%;
                background: var(--gradientPrimary);
                border-radius: 4px;
                transition: width 0.8s ease;
                position: relative;
            }

            .progress-fill::after {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
                animation: progressShine 2s infinite;
            }

            @keyframes progressShine {
                0% { transform: translateX(-100%); }
                100% { transform: translateX(100%); }
            }

            /* Quick Stats Widget */
            .stats-cards {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 12px;
            }

            .stat-card-modern {
                background: linear-gradient(135deg, #f8f9fa, #ffffff);
                border: 2px solid rgba(0, 30, 67, 0.1);
                border-radius: 16px;
                padding: 14px;
                display: flex;
                align-items: center;
                gap: 12px;
                transition: all 0.3s ease;
                cursor: pointer;
            }

            .stat-card-modern:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 30px rgba(0, 30, 67, 0.15);
                border-color: var(--primaryColor);
            }

            .stat-icon-modern {
                width: 42px;
                height: 42px;
                border-radius: 12px;
                background: var(--gradientPrimary);
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 17px;
                flex-shrink: 0;
            }

            .stat-info h4 {
                font-size: 20px;
                font-weight: 700;
                color: var(--darkColor);
                margin: 0 0 2px 0;
            }

            .stat-info p {
                font-size: 12px;
                color: var(--textLight);
                margin: 0;
                font-weight: 500;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            /* Management Tools Widget */
            .tool-cards {
                display: flex;
                flex-direction: column;
                gap: 20px;
            }

            .tool-card {
                background: rgba(255, 255, 255, 0.9);
                border-radius: 20px;
                border: 2px solid rgba(0, 30, 67, 0.1);
                padding: 25px;
                text-align: center;
                cursor: pointer;
                transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
                position: relative;
                overflow: hidden;
                box-shadow: 0 8px 25px rgba(0, 30, 67, 0.08);
            }

            .tool-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: var(--gradientPrimary);
                transition: left 0.5s ease;
                z-index: -1;
            }

            .tool-card:hover::before {
                left: 0;
            }

            .tool-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 40px rgba(0, 30, 67, 0.15);
                border-color: var(--primaryColor);
            }

            .hexagonal {
                clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
                background: linear-gradient(135deg, rgba(0, 30, 67, 0.05), rgba(0, 42, 92, 0.05));
                height: 140px;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 15px;
                transition: all 0.3s ease;
            }

            .tool-card:hover .hexagonal {
                transform: scale(1.05);
                background: var(--gradientPrimary);
            }

            .tool-card:hover .hexagonal i {
                color: white;
                transform: scale(1.1);
            }

            .hex-content {
                text-align: center;
                color: var(--primaryColor);
                transition: all 0.3s ease;
            }

            .hex-content i {
                font-size: 32px;
                display: block;
                margin-bottom: 8px;
                transition: all 0.3s ease;
            }

            .hex-content h4 {
                font-size: 16px;
